<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>${projectName!'项目名称'} - ${table.tableComment}API接口文档</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --bg: #f5f7fb;
            --card: #ffffff;
            --text: #1f2937;
            --sub: #4b5563;
            --line: #e5e7eb;
            --blue: #2563eb;
            --blue-soft: #eff6ff;
            --green: #16a34a;
            --green-soft: #ecfdf3;
            --orange: #f59e0b;
            --orange-soft: #fffbeb;
            --red: #dc2626;
            --red-soft: #fef2f2;
            --gray-soft: #f8fafc;
            --purple: #7c3aed;
            --purple-soft: #f5f3ff;
            --shadow: 0 6px 20px rgba(15, 23, 42, 0.06);
            --radius: 12px;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", "Microsoft YaHei", sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
        }
        .container {
            max-width: 1320px;
            margin: 0 auto;
            padding: 24px;
        }
        h1 {
            font-size: 32px;
            text-align: center;
            margin-bottom: 10px;
            color: #0f172a;
        }
        .page-subtitle {
            text-align: center;
            color: #64748b;
            margin-bottom: 28px;
            font-size: 14px;
        }
        h2 {
            font-size: 24px;
            margin: 34px 0 16px;
            color: #0f172a;
            border-left: 5px solid var(--blue);
            padding-left: 12px;
        }
        h3 {
            font-size: 19px;
            margin: 24px 0 12px;
            color: #111827;
        }
        h4 {
            font-size: 16px;
            margin: 18px 0 10px;
            color: #1f2937;
        }
        p { margin: 8px 0; color: var(--sub); }
        a { color: var(--blue); text-decoration: none; }
        a:hover { text-decoration: underline; }

        .api-card, .toc, .hero-card {
            background: var(--card);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 22px 24px;
            margin-bottom: 20px;
        }

        .hero-card {
            padding: 26px 28px;
            border: 1px solid #dbeafe;
            background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        }

        .info-box, .warn-box, .error-box, .success-box, .tip-box {
            border-radius: 10px;
            padding: 14px 16px;
            margin: 14px 0;
            border-left: 4px solid;
        }
        .info-box { background: var(--blue-soft); border-color: var(--blue); }
        .warn-box { background: var(--orange-soft); border-color: var(--orange); }
        .error-box { background: var(--red-soft); border-color: var(--red); }
        .success-box { background: var(--green-soft); border-color: var(--green); }
        .tip-box { background: var(--purple-soft); border-color: var(--purple); }

        .legend {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 12px;
        }
        .tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            padding: 4px 10px;
            font-size: 12px;
            font-weight: 600;
        }
        .tag-required { background: #fee2e2; color: #b91c1c; }
        .tag-business { background: #dbeafe; color: #1d4ed8; }
        .tag-conditional { background: #fef3c7; color: #b45309; }
        .tag-optional { background: #e5e7eb; color: #374151; }

        .method-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 8px;
            color: #fff;
            font-weight: 700;
            font-size: 13px;
            margin-right: 10px;
            vertical-align: middle;
        }
        .method-post { background: #22c55e; }
        .method-get { background: #3b82f6; }
        .method-put { background: #f59e0b; }
        .method-delete { background: #ef4444; }

        .url {
            font-family: Consolas, Monaco, "Courier New", monospace;
            font-size: 15px;
            font-weight: 700;
            color: #111827;
            word-break: break-all;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin: 12px 0;
            font-size: 14px;
            background: #fff;
        }
        th, td {
            border: 1px solid var(--line);
            padding: 10px 12px;
            vertical-align: top;
        }
        th {
            background: #f8fafc;
            color: #111827;
            font-weight: 700;
            text-align: left;
        }
        tr:nth-child(even) td { background: #fcfcfd; }

        .level {
            font-weight: 700;
            font-size: 12px;
            display: inline-block;
            padding: 2px 8px;
            border-radius: 999px;
            white-space: nowrap;
        }
        .level.required { background: #fee2e2; color: #b91c1c; }
        .level.business { background: #dbeafe; color: #1d4ed8; }
        .level.conditional { background: #fef3c7; color: #b45309; }
        .level.optional { background: #e5e7eb; color: #4b5563; }

        code {
            background: #f3f4f6;
            border-radius: 6px;
            padding: 2px 6px;
            font-family: Consolas, Monaco, "Courier New", monospace;
            color: #be123c;
            font-size: 13px;
        }
        pre {
            background: #0f172a;
            color: #e5e7eb;
            border-radius: 12px;
            padding: 18px;
            overflow-x: auto;
            margin: 12px 0;
            font-size: 13px;
            line-height: 1.6;
        }
        pre code {
            background: transparent;
            color: inherit;
            padding: 0;
        }

        .toc ul { list-style: none; padding-left: 0; }
        .toc li { margin: 6px 0; }
        .toc li ul { padding-left: 20px; margin-top: 6px; }

        .flow-step {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin: 10px 0;
        }
        .flow-step .step-num {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: var(--blue);
            color: #fff;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            margin-top: 2px;
        }
        .flow-step .step-text { color: var(--sub); }

        .section-divider {
            border: none;
            border-top: 1px dashed #cbd5e1;
            margin: 22px 0;
        }

        .version-table th {
            background: var(--blue);
            color: #fff;
        }

        .response-example {
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 12px;
            margin: 10px 0;
        }

        .tab-container { margin-top: 14px; }
        .tab-buttons {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 10px;
        }
        .tab-btn {
            border: 1px solid #cbd5e1;
            background: #fff;
            color: #334155;
            padding: 8px 14px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: .2s ease;
        }
        .tab-btn.active {
            background: #0f172a;
            color: #fff;
            border-color: #0f172a;
        }
        .tab-content { display: none; }
        .tab-content.active { display: block; }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 14px;
            margin-top: 16px;
        }
        .kpi-item {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 14px;
        }
        .kpi-label {
            font-size: 12px;
            color: #64748b;
            margin-bottom: 6px;
        }
        .kpi-value {
            font-size: 15px;
            font-weight: 700;
            color: #111827;
            word-break: break-all;
        }

        .footer {
            text-align: center;
            color: #94a3b8;
            padding: 34px 0 12px;
            font-size: 13px;
        }

        .muted { color: #6b7280; }
        .nowrap { white-space: nowrap; }

        @media (max-width: 768px) {
            .container { padding: 14px; }
            h1 { font-size: 24px; }
            h2 { font-size: 20px; }
            .api-card, .toc, .hero-card { padding: 16px; }
            th, td { font-size: 13px; padding: 8px; }
        }

        .col-2>th { width: 40%; }

        /* 嵌套子对象：分组标题行 */
        .nested-group-header > td {
            background: #dbeafe;
            font-weight: 700;
            color: #1e3a8a;
            border-top: 2px solid #93c5fd;
            border-bottom: 1px solid #93c5fd;
            font-size: 13.5px;
        }
        /* 嵌套子对象：子字段行首列缩进 */
        .nested-field > td:first-child {
            padding-left: 28px;
        }
        /* 嵌套子字段内分组小标题行 */
        .nested-sub-header > td {
            background: #eef2ff;
            font-weight: 700;
            color: #3730a3;
            padding-left: 28px !important;
        }
    </style>
</head>
<body>
<div class="container">

    <h1>${projectName!'项目名称'} - ${table.tableComment} API 接口文档</h1>
    <div class="page-subtitle">版本：V1.0 | 生成时间：${.now?string('yyyy-MM-dd HH:mm:ss')} | 作者：${author!'代码生成器'}</div>

    <div class="hero-card">
        <h3>文档说明</h3>
        <p>
            本文档用于描述 <strong>${table.tableComment}</strong> 模块的 API 接口定义、请求结构、字段说明与校验规则。
        </p>

        <div class="legend">
            <span class="tag tag-required">必填：所有请求必须携带</span>
            <span class="tag tag-business">业务必填：存在该业务时强校验</span>
            <span class="tag tag-conditional">条件必填：满足特定条件时必填</span>
            <span class="tag tag-optional">选填：非必填字段</span>
        </div>

        <div class="info-box">
            <strong>提示：</strong>
            <br />所有接口均需要 Bearer Token 认证，请在请求头中携带 <code>Authorization: Bearer {access_token}</code>
        </div>
    </div>

    <div class="api-card">
        <h3>版本变动记录</h3>
        <table class="version-table">
            <tr>
                <th style="width:120px;">版本</th>
                <th style="width:140px;">更新时间</th>
                <th>变更内容</th>
                <th style="width:120px;">修改人</th>
            </tr>
            <tr>
                <td>V1.0</td>
                <td>${.now?string('yyyy-MM-dd')}</td>
                <td>初始版本，自动生成基础 CRUD 接口文档。</td>
                <td>${author!'代码生成器'}</td>
            </tr>
        </table>
    </div>

    <div class="toc">
        <h3>目录</h3>
        <ul>
            <li><a href="#overview">1. 概述</a></li>
            <li><a href="#auth">2. 认证方式</a></li>
            <li>
                <a href="#apis">3. 接口列表</a>
                <ul>
#foreach ($api in $apis)
                    <li><a href="#api-${foreach.index}">${foreach.index + 1}.${foreach.index + 1} ${api.description}</a></li>
#end
                </ul>
            </li>
            <li><a href="#data-model">4. 数据模型</a></li>
            <li><a href="#error-codes">5. 错误码与统一响应</a></li>
            <li><a href="#code-examples">6. 代码示例</a></li>
        </ul>
    </div>

    <h2 id="overview">1. 概述</h2>
    <div class="api-card">
        <p>本文档描述 <strong>${table.tableComment}</strong> 模块的 RESTful API 接口。支持数据的增删改查及分页查询等操作。</p>

        <div class="kpi-grid">
            <div class="kpi-item">
                <div class="kpi-label">基础地址（Base URL）</div>
                <div class="kpi-value">http://{host}:{port}</div>
            </div>
            <div class="kpi-item">
                <div class="kpi-label">接口前缀</div>
                <div class="kpi-value">/admin-api/${table.moduleName}/${table.businessName}</div>
            </div>
            <div class="kpi-item">
                <div class="kpi-label">认证方式</div>
                <div class="kpi-value">Bearer Token</div>
            </div>
            <div class="kpi-item">
                <div class="kpi-label">数据格式</div>
                <div class="kpi-value">JSON</div>
            </div>
            <div class="kpi-item">
                <div class="kpi-label">表名</div>
                <div class="kpi-value">${table.tableName}</div>
            </div>
            <div class="kpi-item">
                <div class="kpi-label">主键字段</div>
                <div class="kpi-value">${table.primaryKey!'id'}</div>
            </div>
        </div>
    </div>

    <h2 id="auth">2. 认证方式</h2>
    <div class="api-card">
        <p>所有接口均需要 Bearer Token。Token 通过 OAuth2 <code>client_credentials</code> 模式获取。</p>

        <h4>获取 Token 流程</h4>
        <div class="flow-step"><span class="step-num">1</span><span class="step-text">使用客户端 <code>clientId</code> 与 <code>clientSecret</code> 调用 Token 端点获取 <code>access_token</code></span></div>
        <div class="flow-step"><span class="step-num">2</span><span class="step-text">后续请求在请求头中携带 <code>Authorization: Bearer {access_token}</code></span></div>
        <div class="flow-step"><span class="step-num">3</span><span class="step-text">Token 失效后重新获取</span></div>

        <hr class="section-divider" />

        <h4>公共请求头</h4>
        <table>
            <tr><th>Header</th><th>值</th><th>说明</th></tr>
            <tr><td><code>Authorization</code></td><td><code>Bearer {access_token}</code></td><td>认证令牌</td></tr>
            <tr><td><code>Content-Type</code></td><td><code>application/json</code></td><td>请求体格式</td></tr>
        </table>
    </div>

    <h2 id="apis">3. 接口列表</h2>

#foreach ($api in $apis)
    <div class="api-card" id="api-${foreach.index}">
        <h3><span class="method-badge method-${api.method?lower_case}">${api.method}</span><span class="url">${api.path}</span></h3>
        <p>${api.description}</p>

#if ($api.requestParams && $api.requestParams.size() > 0)
        <h4>请求参数</h4>
        <table>
            <tr>
                <th style="width:220px;">字段名</th>
                <th style="width:110px;">类型</th>
                <th style="width:110px;">必填级别</th>
                <th>说明</th>
            </tr>
#foreach ($param in $api.requestParams)
            <tr>
                <td><code>${param.name}</code></td>
                <td>${param.type}</td>
                <td>
#if ($param.required)
                    <span class="level required">必填</span>
#elseif ($param.businessRequired)
                    <span class="level business">业务必填</span>
#elseif ($param.conditionalRequired)
                    <span class="level conditional">条件必填</span>
#else
                    <span class="level optional">选填</span>
#end
                </td>
                <td>${param.description!'-'}</td>
            </tr>
#end
        </table>
#end

#if ($api.requestBody)
        <h4>请求体示例</h4>
        <div class="response-example">
<pre><code>${api.requestBody}</code></pre>
        </div>
#end

#if ($api.responseExample)
        <h4>成功响应</h4>
        <div class="response-example">
<pre><code>${api.responseExample}</code></pre>
        </div>
#end
    </div>
#end

    <h2 id="data-model">4. 数据模型</h2>
    <div class="api-card">
        <h3>4.1 ${table.tableComment}（${table.tableName}）</h3>
        <table>
            <tr>
                <th style="width:200px;">字段名</th>
                <th style="width:120px;">类型</th>
                <th style="width:80px;">必填</th>
                <th>说明</th>
            </tr>
#foreach ($column in $columns)
            <tr>
                <td><code>${column.columnName}</code></td>
                <td>${column.javaType}</td>
                <td>
#if ($column.nullable == false)
                    <span class="level required">必填</span>
#else
                    <span class="level optional">选填</span>
#end
                </td>
                <td>${column.columnComment!'-'}</td>
            </tr>
#end
        </table>
    </div>

    <h2 id="error-codes">5. 错误码与统一响应</h2>
    <div class="api-card">
        <h4>HTTP / 业务码</h4>
        <table>
            <tr><th>HTTP 状态码</th><th>业务 code</th><th>说明</th></tr>
            <tr><td>200</td><td>0</td><td>请求成功</td></tr>
            <tr><td>200</td><td>非 0</td><td>业务失败，具体详见 <code>msg</code></td></tr>
            <tr><td>400</td><td>-</td><td>参数校验失败</td></tr>
            <tr><td>401</td><td>-</td><td>未认证 / Token 无效 / Token 过期</td></tr>
            <tr><td>403</td><td>-</td><td>无权限访问</td></tr>
            <tr><td>404</td><td>-</td><td>资源不存在</td></tr>
            <tr><td>500</td><td>-</td><td>服务器内部错误</td></tr>
        </table>

        <h4>统一响应格式</h4>
        <div class="response-example">
<pre><code>{
  "code": 0,
  "data": { },
  "msg": ""
}</code></pre>
        </div>
    </div>

    <h2 id="code-examples">6. 代码示例</h2>

    <div class="api-card">
        <h3>6.1 分页查询示例</h3>
        <div class="tab-container">
            <div class="tab-buttons">
                <div class="tab-btn active" onclick="switchTab(this, 'query-java')">Java</div>
                <div class="tab-btn" onclick="switchTab(this, 'query-python')">Python</div>
                <div class="tab-btn" onclick="switchTab(this, 'query-curl')">cURL</div>
            </div>

            <div id="query-java" class="tab-content active">
<pre><code>// 使用 Hutool HTTP 客户端
String url = "http://localhost:8080/admin-api/${table.moduleName}/${table.businessName}/page";
Map&lt;String, Object&gt; params = new HashMap&lt;&gt;();
params.put("pageNo", 1);
params.put("pageSize", 10);

HttpResponse response = HttpRequest.get(url)
    .header("Authorization", "Bearer " + accessToken)
    .form(params)
    .execute();

System.out.println(response.body());</code></pre>
            </div>

            <div id="query-python" class="tab-content">
<pre><code>import requests

url = "http://localhost:8080/admin-api/${table.moduleName}/${table.businessName}/page"
params = {"pageNo": 1, "pageSize": 10}

response = requests.get(
    url,
    headers={"Authorization": f"Bearer {access_token}"},
    params=params
)

print(response.json())</code></pre>
            </div>

            <div id="query-curl" class="tab-content">
<pre><code>curl -X GET "http://localhost:8080/admin-api/${table.moduleName}/${table.businessName}/page?pageNo=1&pageSize=10" \
  -H "Authorization: Bearer {access_token}" \
  -H "Content-Type: application/json"</code></pre>
            </div>
        </div>
    </div>

    <div class="api-card">
        <h3>6.2 新增数据示例</h3>
        <div class="tab-container">
            <div class="tab-buttons">
                <div class="tab-btn active" onclick="switchTab(this, 'create-java')">Java</div>
                <div class="tab-btn" onclick="switchTab(this, 'create-python')">Python</div>
                <div class="tab-btn" onclick="switchTab(this, 'create-curl')">cURL</div>
            </div>

            <div id="create-java" class="tab-content active">
<pre><code>String url = "http://localhost:8080/admin-api/${table.moduleName}/${table.businessName}/create";

JSONObject body = new JSONObject();
#foreach ($column in $columns)
#if ($column.columnName != 'id' && $column.columnName != 'createTime' && $column.columnName != 'updateTime' && $column.columnName != 'deleted')
body.set("${column.columnName}", ${column.javaTypeDefaultValue!'null'}); // ${column.columnComment!'-'}
#end
#end

HttpResponse response = HttpRequest.post(url)
    .header("Authorization", "Bearer " + accessToken)
    .header("Content-Type", "application/json")
    .body(body.toString())
    .execute();

System.out.println(response.body());</code></pre>
            </div>

            <div id="create-python" class="tab-content">
<pre><code>import requests

url = "http://localhost:8080/admin-api/${table.moduleName}/${table.businessName}/create"

body = {
#foreach ($column in $columns)
#if ($column.columnName != 'id' && $column.columnName != 'createTime' && $column.columnName != 'updateTime' && $column.columnName != 'deleted')
    "${column.columnName}": None,  # ${column.columnComment!'-'}
#end
#end
}

response = requests.post(
    url,
    headers={
        "Authorization": f"Bearer {access_token}",
        "Content-Type": "application/json"
    },
    json=body
)

print(response.json())</code></pre>
            </div>

            <div id="create-curl" class="tab-content">
<pre><code>curl -X POST "http://localhost:8080/admin-api/${table.moduleName}/${table.businessName}/create" \
  -H "Authorization: Bearer {access_token}" \
  -H "Content-Type: application/json" \
  -d '{
    #foreach ($column in $columns)
#if ($column.columnName != 'id' && $column.columnName != 'createTime' && $column.columnName != 'updateTime' && $column.columnName != 'deleted')
    "${column.columnName}": ${column.javaTypeDefaultValue!'null'}#if($foreach.hasNext),#end
#end
#end
  }'</code></pre>
            </div>
        </div>
    </div>

    <div class="footer">
        ${projectName!'项目名称'} - ${table.tableComment} API 接口文档（V1.0）
    </div>
</div>

<script>
    function switchTab(btn, contentId) {
        var container = btn.closest('.tab-container');
        var buttons = container.querySelectorAll('.tab-btn');
        var contents = container.querySelectorAll('.tab-content');

        buttons.forEach(function(b) { b.classList.remove('active'); });
        contents.forEach(function(c) { c.classList.remove('active'); });

        btn.classList.add('active');
        document.getElementById(contentId).classList.add('active');
    }
</script>
</body>
</html>